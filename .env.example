# HTTP server
HTTP_PORT=8080
HTTP_HOST=0.0.0.0

# Data directory for reference and config files
DATA_DIR=resources

# Pre-built binary index directory (mmap path — skips JSON parsing + tree build)
# Leave empty to fall back to JSON parsing at startup
INDEX_DIR=

# Reference dataset (3M labeled vectors, gzipped — only used when INDEX_DIR is empty)
REFERENCES_FILE=references.json.gz

# Pre-allocate arrays for this many records (avoids costly resizing)
REFERENCES_EXPECTED_COUNT=3100000

# Normalization constants
NORMALIZATION_FILE=normalization.json

# MCC risk scores
MCC_RISK_FILE=mcc_risk.json
